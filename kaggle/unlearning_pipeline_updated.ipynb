       from transformers import BitsAndBytesConfig\n        bnb_config = BitsAndBytesConfig(\n            load_in_4bit=(bits==4),\n            load_in_8bit=(bits==8),\n            bnb_4bit_compute_dtype=torch.float16\n        )\n        model = AutoModelForCausalLM.from_pretrained(\n            model_path,\n            quantization_config=bnb_config,\n            device_map=\"auto\"\n        )\n    else:   \n        model = AutoModelForCausalLM.from_pretrained(\n            model_path,\n            torch_dtype=torch.float16,\n            device_map=\"auto\"\n        )\n    model.eval() \n    print(f\"Successfully loaded '{model_name}' to {model.device}!\\n\")\n    return model, tokenizer\n\ndef generate_continuation(model, tokenizer, prompt, max_tokens=150):\n    \"\"\"Takes a raw text prompt and predicts the verbatim continuation (No Chat Template).\"\"\"\n    inputs = tokenizer(prompt, return_tensors=\"pt\").to(model.device)\n    input_length = inputs[\"input_ids\"].shape[1]\n    \n    with torch.no_grad():\n        outputs = model.generate(\n            **inputs,\n            max_new_tokens=max_tokens,\n            # Lower temperature for raw text completion makes verbatim matching easier to spot\n            do_sample=True, \n            temperature=0.3, \n            top_p=0.9,\n            pad_token_id=tokenizer.eos_token_id\n        )\n        \n    new_tokens = outputs[0][input_length:]\n    return tokenizer.decode(new_tokens, skip_special_tokens=True)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-10T16:48:17.742551Z","iopub.execute_input":"2026-04-10T16:48:17.742828Z","iopub.status.idle":"2026-04-10T16:48:17.755018Z","shell.execute_reply.started":"2026-04-10T16:48:17.742797Z","shell.execute_reply":"2026-04-10T16:48:17.754471Z"}},"outputs":[],"execution_count":15},{"cell_type":"code","source":"base_model, base_tokenizer = load_inference_model(\"Base Model (Download/Cache)\")\ntest_model, test_tokenizer = load_inference_model(\"unlearned_task_vector\")\nquantized4_model, quantized4_tokenizer = load_inference_model(\"unlearned_task_vector\", is_quantized=True, bits=4)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-10T16:48:17.755831Z","iopub.execute_input":"2026-04-10T16:48:17.756073Z","iopub.status.idle":"2026-04-10T16:48:28.669922Z","shell.execute_reply.started":"2026-04-10T16:48:17.756039Z","shell.execute_reply":"2026-04-10T16:48:28.669311Z"}},"outputs":[{"name":"stdout","text":"Loading 'Base Model (Download/Cache)'. This might take a minute...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/340 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"58ef3579e78141d3bf3379bc078adea5"}},"metadata":{}},{"name":"stdout","text":"Successfully loaded 'Base Model (Download/Cache)' to cuda:0!\n\nLoading 'unlearned_task_vector'. This might take a minute...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/340 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"b17591a0101b4ad0857fbbb00545b7f4"}},"metadata":{}},{"name":"stdout","text":"Successfully loaded 'unlearned_task_vector' to cuda:0!\n\nLoading 'unlearned_task_vector'. This might take a minute...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/340 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"7ac01d1bb99849b0a813fb36cdbe08b3"}},"metadata":{}},{"name":"stdout","text":"Successfully loaded 'unlearned_task_vector' to cuda:1!\n\n","output_type":"stream"}],"execution_count":16},{"cell_type":"code","source":"print(\"=\"*50)\nprint(f\"📖 Raw Text Probing: TV Unlearned\")\nprint(\"Paste the beginning of a sentence from the book to see if it can finish it.\")\nprint(\"